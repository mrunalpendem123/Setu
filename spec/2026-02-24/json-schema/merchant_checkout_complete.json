{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["payment_data"],
  "properties": {
    "payment_data": {
      "type": "object",
      "additionalProperties": false,
      "required": ["provider", "token"],
      "properties": {
        "provider": {"type": "string"},
        "token": {"type": "string"},
        "billing_address": {"type": "object"},
        "approval_required": {
          "type": "boolean",
          "default": false,
          "description": "If true, the merchant must review before charging. Session transitions to pending_approval instead of completing immediately."
        }
      }
    }
  }
}
