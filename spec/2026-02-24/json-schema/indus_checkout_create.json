{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "additionalProperties": false,
  "required": ["merchant_base_url", "items"],
  "properties": {
    "merchant_base_url": {"type": "string"},
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "quantity"],
        "properties": {
          "id": {"type": "string"},
          "quantity": {"type": "integer", "minimum": 1}
        }
      }
    },
    "buyer": {"type": "object"},
    "fulfillment_address": {"type": "object"},
    "capabilities": {
      "description": "Agent capabilities to declare to the merchant. If omitted, Indus sends its default Setu capabilities (Hyperswitch UPI + card, india_gst, upi_vpa, discounts).",
      "type": "object",
      "properties": {
        "payment_methods": {"type": "array", "items": {"type": "string"}},
        "payment_handlers": {"type": "array", "items": {"type": "object"}},
        "extensions": {"type": "array", "items": {"type": "string"}},
        "locale": {"type": "string"},
        "timezone": {"type": "string"}
      }
    }
  }
}
