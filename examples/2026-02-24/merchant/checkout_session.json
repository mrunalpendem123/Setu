  "stage_2_address_provided_no_option": {
    "description": "Fulfillment token provided but no option selected yet",
    "messages_example": [
      {
        "type": "info",
        "severity": "info",
        "content_type": "plain",
        "content": "Select a fulfillment option to proceed",
        "param": "fulfillment_option_id"
      }
    ]
  },

  "stage_3_low_stock_warning": {
    "description": "Session is ready but a low-stock warning is attached",
    "messages_example": [
      {
        "type": "warning",
        "code": "low_stock",
        "severity": "low",
        "content_type": "plain",
        "content": "Only a few units of 'Indus Hoodie' remain",
        "param": "items"
      }
    ]
  },

  "stage_4_3ds_required": {
    "description": "Payment attempt triggered 3DS; session transitions to authentication_required",
    "status": "authentication_required",
    "messages_example": [
      {
        "type": "error",
        "code": "requires_3ds",
        "severity": "high",
        "content_type": "plain",
        "content": "3D Secure authentication is required to complete payment",
        "param": "payment_data.token"
      }
    ]
  },

  "stage_5_pending_approval": {
    "description": "B2B order submitted with approval_required=true; pending merchant review",
    "status": "pending_approval",
    "messages_example": [
      {
        "type": "info",
        "severity": "medium",
        "content_type": "plain",
        "content": "Your order is awaiting merchant approval before payment is collected"
      }
    ]
  }
}
