# ── Hyperswitch (payment processor) ──────────────────────────────────────────
HYPERSWITCH_API_KEY=your_api_key_here
HYPERSWITCH_PUBLISHABLE_KEY=pk_dev_...
HYPERSWITCH_ADMIN_API_KEY=admin_...
HYPERSWITCH_VAULT_API_KEY=vault_...
HYPERSWITCH_BASE_URL=https://sandbox.hyperswitch.io
HYPERSWITCH_MERCHANT_ID=
HYPERSWITCH_PROFILE_ID=
HYPERSWITCH_ACCEPTED_STATUSES=succeeded,processing,requires_capture,requires_customer_action

# ── Sarvam AI ─────────────────────────────────────────────────────────────────
SARVAM_API_KEY=your_sarvam_key
SARVAM_BASE_URL=https://api.sarvam.ai
SARVAM_MODEL=sarvam-m

# ── PSP (delegated payment stub) ──────────────────────────────────────────────
PSP_API_KEYS=demo_key
DELEGATED_PSP_BASE_URL=http://localhost:8002
DELEGATED_PSP_API_KEY=demo_key
DELEGATED_PSP_API_VERSION=2026-02-24

# ── Indus orchestrator ────────────────────────────────────────────────────────
INDUS_API_KEY=indus_secret
TOKEN_TTL_SECONDS=86400
PAYMENTS_SERVICE_URL=                # leave blank to call Hyperswitch directly

# ── Merchant ──────────────────────────────────────────────────────────────────
MERCHANT_API_KEY=merchant_secret
MERCHANT_DEFAULT_LOCALE=en-IN
MERCHANT_DEFAULT_TIMEZONE=Asia/Kolkata
MERCHANT_CONTINUE_URL=https://merchant.example.in/checkout
MERCHANT_ORDERS_URL=https://merchant.example.in/orders
MERCHANT_PRIVACY_URL=https://merchant.example.in/privacy
MERCHANT_TOS_URL=https://merchant.example.in/terms
MERCHANT_SUPPORT_URL=https://merchant.example.in/support

# ── Session ───────────────────────────────────────────────────────────────────
SESSION_TTL_HOURS=24

# ── Webhooks ──────────────────────────────────────────────────────────────────
ORDER_WEBHOOK_URL=https://your-webhook-receiver.example.in/webhook
ORDER_WEBHOOK_SECRET=your_webhook_secret
ORDER_WEBHOOK_TIMEOUT_SECONDS=5
ORDER_WEBHOOK_MAX_RETRIES=3
ORDER_WEBHOOK_RETRY_BACKOFF_MS=200
ORDER_EVENT_STYLE=dot                # dot = "order.created" | underscore = "order_created"

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+psycopg://setu:setu@localhost:5432/indus

# ── Security ──────────────────────────────────────────────────────────────────
ACP_API_KEYS=demo_key
ACP_API_VERSION=2026-02-24
ACP_SIGNATURE_SECRET=                # leave blank to skip signature validation
ACP_TIMESTAMP_TOLERANCE_SECONDS=300

# ── Rate limiting ─────────────────────────────────────────────────────────────
RATE_LIMIT_ENABLED=true

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
